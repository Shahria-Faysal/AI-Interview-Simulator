// Prisma Schema for AI Interview Simulator
// Phase 5 - Resume-aware personalized interview question generation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  resumes           Resume[]
  interviewSessions InterviewSession[]

  @@map("users")
}

model Resume {
  id         String   @id @default(cuid())
  userId     String
  fileUrl    String
  fileName   String
  fileSize   Int
  uploadedAt DateTime @default(now())

  // ── Phase 5: Resume parsing & AI analysis fields ─────────────────────────
  // All nullable — populated asynchronously after upload.
  // analysisStatus tracks the processing pipeline state so we never
  // re-process or call Gemini twice for the same file.
  extractedText    String?   // raw text extracted from the PDF
  parsedAt         DateTime? // when pdf-parse completed
  detectedSkills   Json?     // string[] — e.g. ["React", "Node.js"]
  detectedProjects Json?     // string[] — e.g. ["E-commerce platform"]
  analysisData     Json?     // full Gemini output { skills, projects, experienceLevel, domains }
  analysisStatus   String    @default("pending") // "pending"|"processing"|"done"|"failed"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resumes")
}

// Enum types for interview configuration
enum Role {
  FRONTEND_DEVELOPER
  BACKEND_DEVELOPER
  FULL_STACK_DEVELOPER
  DATA_ANALYST
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// Tracks whether questions came from Gemini or the hardcoded fallback bank
enum QuestionSource {
  AI       // Generated by Google Gemini
  FALLBACK // Loaded from the hardcoded question bank (Gemini unavailable)
}

model InterviewSession {
  id             String         @id @default(cuid())
  userId         String
  role           Role
  difficulty     Difficulty
  questionSource QuestionSource @default(FALLBACK) // "AI" or "FALLBACK"
  score          Float?         // null until session is completed
  startedAt      DateTime       @default(now())
  completedAt    DateTime?      // null until session is completed

  // ── Phase 5: Personalization flag ────────────────────────────────────────
  // true when questions were generated using the candidate's resume analysis.
  isPersonalized Boolean @default(false)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions Question[]

  @@map("interview_sessions")
}

model Question {
  id         String   @id @default(cuid())
  sessionId  String
  question   String
  answer     String?  // user's submitted answer
  orderIndex Int      // display order within the session

  // ── Phase 4: AI evaluation fields ───────────────────────────────────────
  // All nullable — populated after the user submits an answer and Gemini
  // evaluates it. If Gemini is unavailable, these remain null (never crash).
  score       Float?    // 1–10 from Gemini (null = not yet evaluated)
  strengths   String[]  // array of strength bullet points
  weaknesses  String[]  // array of weakness bullet points
  suggestions String[]  // array of improvement suggestions
  idealAnswer String?   // model answer from Gemini

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("questions")
}
