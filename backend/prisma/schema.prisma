// Prisma Schema for AI Interview Simulator
// Phase 3 - AI-powered question generation via Google Gemini

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  resumes           Resume[]
  interviewSessions InterviewSession[]

  @@map("users")
}

model Resume {
  id         String   @id @default(cuid())
  userId     String
  fileUrl    String
  fileName   String
  fileSize   Int
  uploadedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resumes")
}

// Enum types for interview configuration
enum Role {
  FRONTEND_DEVELOPER
  BACKEND_DEVELOPER
  FULL_STACK_DEVELOPER
  DATA_ANALYST
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// Tracks whether questions came from Gemini or the hardcoded fallback bank
enum QuestionSource {
  AI       // Generated by Google Gemini
  FALLBACK // Loaded from the hardcoded question bank (Gemini unavailable)
}

model InterviewSession {
  id             String         @id @default(cuid())
  userId         String
  role           Role
  difficulty     Difficulty
  questionSource QuestionSource @default(FALLBACK) // "AI" or "FALLBACK"
  score          Float?         // null until session is completed
  startedAt      DateTime       @default(now())
  completedAt    DateTime?      // null until session is completed

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions Question[]

  @@map("interview_sessions")
}

model Question {
  id         String  @id @default(cuid())
  sessionId  String
  question   String
  answer     String? // user's submitted answer
  feedback   String? // placeholder for Phase 2 AI feedback
  score      Float?  // placeholder for Phase 2 AI scoring
  orderIndex Int     // display order within the session

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("questions")
}
